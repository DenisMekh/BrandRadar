{
  "id": null,
  "uid": "brandradar-runtime",
  "title": "BrandRadar Go Runtime",
  "tags": [
    "brandradar",
    "runtime",
    "go"
  ],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "interval",
        "label": "Interval",
        "type": "custom",
        "query": "1m,5m,10m,30m,1h",
        "current": {
          "text": "5m",
          "value": "5m"
        },
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Goroutines & Threads",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Goroutines",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "go_goroutines"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Threads",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "go_threads"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Memory",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Heap Memory",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "go_memstats_heap_alloc_bytes",
          "legendFormat": "Heap Alloc"
        },
        {
          "refId": "B",
          "expr": "go_memstats_heap_sys_bytes",
          "legendFormat": "Heap Sys"
        },
        {
          "refId": "C",
          "expr": "go_memstats_heap_inuse_bytes",
          "legendFormat": "Heap InUse"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Stack Memory",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "go_memstats_stack_inuse_bytes",
          "legendFormat": "Stack InUse"
        },
        {
          "refId": "B",
          "expr": "go_memstats_stack_sys_bytes",
          "legendFormat": "Stack Sys"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Total Alloc",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "go_memstats_alloc_bytes"
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Garbage Collection",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "GC Pause Duration",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(go_gc_duration_seconds_sum[$interval])",
          "legendFormat": "GC time"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "GC Operations",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(go_gc_duration_seconds_count[$interval])",
          "legendFormat": "GC ops/sec"
        }
      ]
    },
    {
      "id": 11,
      "type": "row",
      "title": "Process",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Open File Descriptors",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_open_fds",
          "legendFormat": "Open FDs"
        },
        {
          "refId": "B",
          "expr": "process_max_fds",
          "legendFormat": "Max FDs"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Process CPU",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(process_cpu_seconds_total[$interval])",
          "legendFormat": "CPU seconds"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Process Resident Memory",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS"
        }
      ]
    }
  ]
}
