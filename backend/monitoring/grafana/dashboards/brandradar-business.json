{
  "id": null,
  "uid": "brandradar-business",
  "title": "BrandRadar Business Metrics",
  "tags": [
    "brandradar",
    "business"
  ],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "interval",
        "label": "Interval",
        "type": "custom",
        "query": "1m,5m,10m,30m,1h",
        "current": {
          "text": "5m",
          "value": "5m"
        },
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Mentions",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Mentions Created Rate",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(brandradar_mentions_created_total[$interval])) by (brand_id, source)",
          "legendFormat": "brand={{brand_id}} src={{source}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Mentions Total",
      "datasource": null,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(brandradar_mentions_created_total)"
        }
      ]
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "Mentions by Source",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(brandradar_mentions_created_total) by (source)",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Mentions by Brand",
      "datasource": null,
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(brandradar_mentions_created_total) by (brand_id)",
          "legendFormat": "{{brand_id}}"
        }
      ],
      "options": {
        "orientation": "horizontal"
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Alerts",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Alerts Fired Rate",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(brandradar_alerts_fired_total[$interval])) by (brand_id)",
          "legendFormat": "brand={{brand_id}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Total Alerts Fired",
      "datasource": null,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(brandradar_alerts_fired_total)"
        }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Alerts by Brand",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 9
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(brandradar_alerts_fired_total) by (brand_id)",
          "legendFormat": "{{brand_id}}"
        }
      ],
      "options": {
        "orientation": "horizontal"
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Ingest Pipeline",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Ingest Items Rate",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(brandradar_ingest_items_total[$interval])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Ingest Duration",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, rate(brandradar_ingest_duration_seconds_bucket[$interval]))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, rate(brandradar_ingest_duration_seconds_bucket[$interval]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Ingest Success vs Error",
      "datasource": null,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Created"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Errors"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(brandradar_ingest_items_total{status=\"created\"})",
          "legendFormat": "Created"
        },
        {
          "refId": "B",
          "expr": "sum(brandradar_ingest_items_total{status=\"error\"})",
          "legendFormat": "Errors"
        }
      ]
    },
    {
      "id": 14,
      "type": "piechart",
      "title": "Ingest Outcomes",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 25
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(brandradar_ingest_items_total) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "row",
      "title": "Sources & Brands Gauges",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Active Sources",
      "datasource": null,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 33
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "brandradar_sources_active_total",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Total Brands",
      "datasource": null,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 33
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "brandradar_brands_total"
        }
      ]
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "API Errors by Endpoint",
      "datasource": null,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(brandradar_api_errors_total[$interval])) by (endpoint, error_code)",
          "legendFormat": "{{endpoint}} {{error_code}}"
        }
      ]
    }
  ]
}
