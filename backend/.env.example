# Application
APP_ENV=local
APP_PORT=8080
APP_LOG_LEVEL=debug

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=app_db
PG_SSL_MODE=disable
PG_MAX_CONNS=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

ML_SENTIMENT_HOST=http://localhost:8000

WORKER_CLUSTERING=3
WORKER_ANALYTICS=1
WORKER_ANOMALIES=2

# Telegram notifications (аномалии)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here